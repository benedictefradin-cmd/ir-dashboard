# URL du Cloudflare Worker (à remplir après déploiement)
VITE_WORKER_URL=https://ir-dashboard-api.YOUR-SUBDOMAIN.workers.dev

# Token GitHub (Personal Access Token)
VITE_GITHUB_TOKEN=your_github_pat_here
VITE_GITHUB_OWNER=your_github_username
VITE_GITHUB_SITE_REPO=institut-rousseau

# Notion (pipeline de publication)
VITE_NOTION_API_KEY=your_notion_integration_token
VITE_NOTION_DATABASE_ID=your_notion_database_id

# Brevo (à configurer plus tard)
# VITE_BREVO_API_KEY=your_brevo_api_key

# Telegram (à configurer plus tard)
# VITE_TELEGRAM_BOT_TOKEN=your_bot_token
# VITE_TELEGRAM_CHAT_ID=your_chat_id
